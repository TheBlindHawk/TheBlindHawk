---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Not Found">
  <div class="flex min-h-[60vh] flex-col items-center justify-center text-center py-20">
    <p class="text-7xl font-bold text-[var(--border)]">404</p>
    <h1 class="mt-4 text-2xl font-semibold">Page not found</h1>
    <p class="mt-3 text-[var(--muted)]">
      This page doesn't exist or was moved.
    </p>
    <a
      href="/"
      class="mt-8 rounded-lg border border-[var(--accent)] px-5 py-2 text-sm text-[var(--accent)] transition-colors hover:bg-[var(--accent)] hover:text-[var(--bg)]"
    >
      Back home
    </a>
  </div>
</BaseLayout>
