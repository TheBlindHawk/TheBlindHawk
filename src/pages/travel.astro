---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import SocialLinks from "../components/SocialLinks.astro";

const entries = await getCollection("travel");
const sorted = entries.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Travel" description="Travel journal and photos by BlindHawk.">
  <div class="py-16">
    <header class="mb-12">
      <p class="mb-2 text-sm tracking-widest text-[var(--accent)]">TRAVEL</p>
      <h1 class="text-4xl font-bold">Journeys</h1>
      <p class="mt-3 text-[var(--muted)]">
        Places visited, photos taken, stories written.
      </p>
    </header>

    {sorted.length > 0 ? (
      <ul class="grid gap-6 sm:grid-cols-2">
        {sorted.map((entry) => (
          <li>
            <article class="group rounded-lg border border-[var(--border)] bg-[var(--surface)] overflow-hidden transition-colors hover:border-[var(--accent)]">
              {entry.data.coverImage && (
                <img
                  src={entry.data.coverImage}
                  alt={entry.data.title}
                  class="h-48 w-full object-cover"
                  loading="lazy"
                />
              )}
              <div class="p-6 flex flex-col gap-2">
                <div class="flex items-center justify-between gap-4">
                  <span class="text-xs text-[var(--accent)] tracking-wider">
                    {entry.data.location}
                  </span>
                  <time class="text-xs text-[var(--muted)]">
                    {entry.data.date.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                    })}
                  </time>
                </div>
                <h2 class="font-medium group-hover:text-[var(--accent)] transition-colors">
                  {entry.data.title}
                </h2>
              </div>
            </article>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-[var(--muted)] text-sm">
        Nothing here yet — check back soon.
      </p>
    )}

    <SocialLinks links={[
      { platform: "Instagram", url: "#" },
      { platform: "YouTube",   url: "#" },
    ]} />
  </div>
</BaseLayout>
