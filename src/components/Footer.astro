---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--border)] mt-24">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-8 text-sm text-[var(--muted)]">
    <span>© {year} BlindHawk</span>
    <a
      href="https://github.com/TheBlindHawk"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-[var(--accent)] transition-colors"
    >
      GitHub
    </a>
  </div>
</footer>
