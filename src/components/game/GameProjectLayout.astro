---
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props {
  title: string;
  projectTitle: string;
  slug: string;
  description?: string;
}

const { title, projectTitle, slug, description } = Astro.props;

const tabs = [
  { href: `/projects/${slug}`,            label: "Overview"    },
  { href: `/projects/${slug}/characters`, label: "Characters"  },
  { href: `/projects/${slug}/gallery`,    label: "Gallery"     },
  { href: `/projects/${slug}/lore`,       label: "Lore"        },
  { href: `/projects/${slug}/map`,        label: "Map"         },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "");
---

<BaseLayout title={`${title} — ${projectTitle}`} description={description}>
  <div class="py-16">
    <!-- Project header -->
    <div class="mb-8">
      <a href="/projects" class="text-xs text-[var(--muted)] hover:text-[var(--accent)] transition-colors">
        ← Projects
      </a>
      <h1 class="mt-3 text-4xl font-bold">{projectTitle}</h1>
    </div>

    <!-- Sub-nav -->
    <nav class="mb-10 flex gap-1 border-b border-[var(--border)]">
      {tabs.map(({ href, label }) => {
        const isActive = currentPath === href;
        return (
          <a
            href={href}
            class={[
              "px-4 py-2 text-sm transition-colors border-b-2 -mb-px",
              isActive
                ? "border-[var(--accent)] text-[var(--accent)]"
                : "border-transparent text-[var(--muted)] hover:text-[var(--text)]",
            ].join(" ")}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <slot />
  </div>
</BaseLayout>
