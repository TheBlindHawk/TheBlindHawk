---
import DnDNav from "../components/dnd/DnDNav.astro";
import "../styles/dnd.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Demons & Divinity",
  description = "A single-player platform RPG — descend into the abyss and uncover the truth of the Divine-Demonic war.",
} = Astro.props;

const fullTitle = title === "Demons & Divinity" ? title : `${title} — Demons & Divinity`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
  </head>
  <body style="background-color: var(--dnd-bg);">
    <DnDNav />
    <main>
      <slot />
    </main>
  </body>
</html>
